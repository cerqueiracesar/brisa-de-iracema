    {
      "parameters": {
        "jsCode": "// 1. Pega o texto gerado pela IA e transforma em um Objeto JSON\nconst dadosDaNota = JSON.parse($input.first().json.output);\nconst itensSeparados = [];\n\n// 2. Faz um loop por todos os produtos que a IA encontrou na nota\nfor (const produto of dadosDaNota.produtos) {\n  \n  // 3. Monta a linha virtual completa para o Google Sheets\n  itensSeparados.push({\n    json: {\n      Data: dadosDaNota.data,\n      Local: dadosDaNota.local,\n      Item: produto.item,\n      Quantidade: produto.quantidade,\n      Preco_Unitario: produto.preco_unitario,\n      Preco_Total: produto.preco_total\n    }\n  });\n}\n\n// 4. Entrega as linhas separadas para o n8n\nreturn itensSeparados;"
      },
