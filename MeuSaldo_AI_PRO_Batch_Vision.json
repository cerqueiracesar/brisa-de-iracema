      "parameters": {
        "jsCode": "// Pega no output de texto do Agente e converte para JSON\nconst resumoDoDia = JSON.parse($input.first().json.output);\nconst linhasSeparadas = [];\n\n// Faz um loop pelas transações consolidadas\nfor (const transacao of resumoDoDia) {\n  linhasSeparadas.push({\n    json: {\n      descricao: transacao.descricao,\n      categoria: transacao.categoria,\n      entrada: transacao.entrada,\n      saida: transacao.saida\n    }\n  });\n}\n\nreturn linhasSeparadas;"
